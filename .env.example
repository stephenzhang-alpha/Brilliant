VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000

# --- Firebase AI Logic (the magical assistant "Pip") ---
# The assistant generates live hints/explanations with Gemini via Firebase AI
# Logic, reusing the Firebase config above. To turn the live AI on:
#   1) From the project root run:  npx -y firebase-tools@latest init ailogic
#      (enables the Gemini Developer API; without it the SDK returns
#       PERMISSION_DENIED and the app falls back to the authored hint text).
#   2) Make sure the VITE_FIREBASE_* values above are real (not placeholders).
# --- App Check (reCAPTCHA Enterprise) — recommended before a public launch ---
# App Check attests that traffic comes from your real app, protecting Auth,
# Firestore, and the Firebase AI Logic quota from bots/abuse. To enable:
#   1) In Google Cloud, create a reCAPTCHA Enterprise key (type: website) for
#      your domain (add localhost for local testing).
#   2) In the Firebase console → App Check, register this web app with the
#      reCAPTCHA Enterprise provider using that key.
#   3) Set VITE_RECAPTCHA_SITE_KEY below to the reCAPTCHA *site key*.
#   4) Turn on enforcement per product (Auth, Firestore, AI Logic) in the
#      console once you've confirmed legitimate traffic passes.
# When set, App Check initializes automatically (see src/firebase/config.ts);
# when empty, it is skipped entirely — fine for local dev.
VITE_RECAPTCHA_SITE_KEY=

# Optional: set to 'true' to point Auth at the local Firebase emulator
# (http://localhost:9099) instead of production during development.
VITE_FIREBASE_USE_EMULATOR=
