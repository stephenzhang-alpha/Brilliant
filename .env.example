VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000

# --- Firebase AI Logic (the magical assistant "Pip") ---
# The assistant generates live hints/explanations with Gemini via Firebase AI
# Logic, reusing the Firebase config above. To turn the live AI on:
#   1) From the project root run:  npx -y firebase-tools@latest init ailogic
#      (enables the Gemini Developer API; without it the SDK returns
#       PERMISSION_DENIED and the app falls back to the authored hint text).
#   2) Make sure the VITE_FIREBASE_* values above are real (not placeholders).
#   3) Strongly recommended before a public launch: enable App Check to protect
#      your AI quota. Create a reCAPTCHA Enterprise key, register it in the
#      Firebase console, and set it below. When set, App Check initializes
#      automatically; when empty, it is skipped (fine for local dev).
VITE_RECAPTCHA_SITE_KEY=
